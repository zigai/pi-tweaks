{
  "name": "@zigai/pi-model-modes",
  "version": "0.5.0",
  "description": "Pi package that adds prompt modes for model and thinking-level switching.",
  "keywords": [
    "mode",
    "pi",
    "pi-coding-agent",
    "pi-extension",
    "pi-package",
    "pi-tweaks"
  ],
  "homepage": "https://github.com/zigai/pi-tweaks/tree/main/packages/pi-model-modes#readme",
  "bugs": {
    "url": "https://github.com/zigai/pi-tweaks/issues"
  },
  "license": "MIT",
  "author": "zigai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zigai/pi-tweaks.git",
    "directory": "packages/pi-model-modes"
  },
  "files": [
    "src",
    "README.md",
    "*.json"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "node ../../scripts/prepare-settings-bundle.ts"
  },
  "dependencies": {
    "@zigai/pi-extension-settings": "0.3.2",
    "typebox": "^1.1.38"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "bundleDependencies": [
    "@zigai/pi-extension-settings"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "piExtensionSettings": {
    "definition": "./src/settings.ts",
    "schema": "./config.schema.json",
    "readme": "./README.md"
  }
}
