{
  "name": "@zigai/pi-footer",
  "version": "0.4.4",
  "description": "Pi package that replaces Pi's footer with a compact status line.",
  "keywords": [
    "footer",
    "pi",
    "pi-coding-agent",
    "pi-extension",
    "pi-package",
    "pi-tweaks"
  ],
  "homepage": "https://github.com/zigai/pi-tweaks/tree/main/packages/pi-footer#readme",
  "bugs": {
    "url": "https://github.com/zigai/pi-tweaks/issues"
  },
  "license": "MIT",
  "author": "zigai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zigai/pi-tweaks.git",
    "directory": "packages/pi-footer"
  },
  "files": [
    "src",
    "assets",
    "README.md",
    "*.json"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./api": "./src/api.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "typebox": "^1.1.38"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "pi": {
    "image": "https://raw.githubusercontent.com/zigai/pi-tweaks/master/packages/pi-footer/assets/footer.png",
    "extensions": [
      "./src/index.ts"
    ]
  }
}
