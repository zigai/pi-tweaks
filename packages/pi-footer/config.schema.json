{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/zigai/pi-tweaks/master/packages/pi-footer/config.schema.json",
  "title": "Pi Footer settings",
  "description": "Settings for footer content, ordering, and separators.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "default": "./schemas/pi-footer.schema.json",
      "description": "JSON Schema used by editors for this settings file."
    },
    "separator": {
      "type": "string",
      "default": "·",
      "description": "Text placed between visible footer slots."
    },
    "layout": {
      "type": "object",
      "properties": {
        "left": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "anyOf": [
                  {
                    "type": "string",
                    "const": "branch"
                  },
                  {
                    "type": "string",
                    "const": "context"
                  },
                  {
                    "type": "string",
                    "const": "mcp"
                  },
                  {
                    "type": "string",
                    "const": "model"
                  },
                  {
                    "type": "string",
                    "const": "path"
                  },
                  {
                    "type": "string",
                    "const": "provider"
                  },
                  {
                    "type": "string",
                    "const": "thinking"
                  }
                ]
              },
              {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9-]*(?:\\.[a-z0-9][a-z0-9-]*)+$"
              }
            ]
          },
          "uniqueItems": true,
          "default": [
            "path",
            "branch",
            "provider",
            "model",
            "thinking"
          ],
          "description": "Footer slot IDs shown on the left in display order."
        },
        "right": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "anyOf": [
                  {
                    "type": "string",
                    "const": "branch"
                  },
                  {
                    "type": "string",
                    "const": "context"
                  },
                  {
                    "type": "string",
                    "const": "mcp"
                  },
                  {
                    "type": "string",
                    "const": "model"
                  },
                  {
                    "type": "string",
                    "const": "path"
                  },
                  {
                    "type": "string",
                    "const": "provider"
                  },
                  {
                    "type": "string",
                    "const": "thinking"
                  }
                ]
              },
              {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9-]*(?:\\.[a-z0-9][a-z0-9-]*)+$"
              }
            ]
          },
          "uniqueItems": true,
          "default": [
            "context"
          ],
          "description": "Footer slot IDs shown on the right in display order."
        },
        "hidden": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "anyOf": [
                  {
                    "type": "string",
                    "const": "path"
                  },
                  {
                    "type": "string",
                    "const": "branch"
                  },
                  {
                    "type": "string",
                    "const": "provider"
                  },
                  {
                    "type": "string",
                    "const": "model"
                  },
                  {
                    "type": "string",
                    "const": "thinking"
                  },
                  {
                    "type": "string",
                    "const": "mcp"
                  },
                  {
                    "type": "string",
                    "const": "context"
                  }
                ]
              },
              {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9-]*(?:\\.[a-z0-9][a-z0-9-]*)+$"
              }
            ]
          },
          "uniqueItems": true,
          "default": [],
          "description": "Footer slot IDs hidden from both sides."
        }
      },
      "default": {},
      "additionalProperties": false
    }
  }
}
