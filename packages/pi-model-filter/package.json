{
  "name": "@zigai/pi-model-filter",
  "version": "0.3.0",
  "description": "Pi package that hides configured models from Pi model selection and lookup.",
  "keywords": [
    "model-filter",
    "pi",
    "pi-coding-agent",
    "pi-extension",
    "pi-package",
    "pi-tweaks"
  ],
  "homepage": "https://github.com/zigai/pi-tweaks/tree/main/packages/pi-model-filter#readme",
  "bugs": {
    "url": "https://github.com/zigai/pi-tweaks/issues"
  },
  "license": "MIT",
  "author": "zigai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zigai/pi-tweaks.git",
    "directory": "packages/pi-model-filter"
  },
  "files": [
    "src",
    "README.md",
    "*.json"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "node ../../scripts/prepare-settings-bundle.ts"
  },
  "dependencies": {
    "@zigai/pi-extension-settings": "0.1.2",
    "typebox": "^1.1.38"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "bundleDependencies": [
    "@zigai/pi-extension-settings"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "piExtensionSettings": {
    "definition": "./src/settings.ts",
    "schema": "./config.schema.json",
    "readme": "./README.md"
  }
}
