{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/zigai/pi-tweaks/master/packages/pi-model-alias/config.schema.json",
  "title": "Pi Model Alias settings",
  "description": "Settings for model and provider display aliases.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "default": "./schemas/pi-model-alias.schema.json",
      "description": "JSON Schema used by editors for this settings file."
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "provider",
          "model",
          "alias"
        ],
        "properties": {
          "provider": {
            "type": "string",
            "pattern": "\\S"
          },
          "model": {
            "type": "string",
            "pattern": "\\S"
          },
          "alias": {
            "type": "string",
            "pattern": "\\S"
          },
          "name": {
            "type": "string",
            "pattern": "\\S"
          }
        },
        "additionalProperties": false
      },
      "default": [],
      "description": "Model alias entries matched by provider and model ID."
    },
    "providerAliases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "provider",
          "name"
        ],
        "properties": {
          "provider": {
            "type": "string",
            "pattern": "\\S"
          },
          "name": {
            "type": "string",
            "pattern": "\\S"
          }
        },
        "additionalProperties": false
      },
      "default": [],
      "description": "Provider display-name aliases."
    },
    "stableProviderColumn": {
      "type": "boolean",
      "default": true,
      "description": "Keep the provider column stable when aliases are displayed."
    }
  }
}
