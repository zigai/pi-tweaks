{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/zigai/pi-tweaks/master/packages/pi-message-highlights/config.schema.json",
  "title": "Pi Message Highlights settings",
  "description": "Settings for highlighting URLs in message output.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "default": "./schemas/pi-message-highlights.schema.json",
      "description": "JSON Schema used by editors for this settings file."
    },
    "urlColor": {
      "anyOf": [
        {
          "anyOf": [
            {
              "type": "string",
              "const": "accent"
            },
            {
              "type": "string",
              "const": "bashMode"
            },
            {
              "type": "string",
              "const": "border"
            },
            {
              "type": "string",
              "const": "borderAccent"
            },
            {
              "type": "string",
              "const": "borderMuted"
            },
            {
              "type": "string",
              "const": "customMessageLabel"
            },
            {
              "type": "string",
              "const": "customMessageText"
            },
            {
              "type": "string",
              "const": "dim"
            },
            {
              "type": "string",
              "const": "error"
            },
            {
              "type": "string",
              "const": "mdCode"
            },
            {
              "type": "string",
              "const": "mdCodeBlock"
            },
            {
              "type": "string",
              "const": "mdCodeBlockBorder"
            },
            {
              "type": "string",
              "const": "mdHeading"
            },
            {
              "type": "string",
              "const": "mdHr"
            },
            {
              "type": "string",
              "const": "mdLink"
            },
            {
              "type": "string",
              "const": "mdLinkUrl"
            },
            {
              "type": "string",
              "const": "mdListBullet"
            },
            {
              "type": "string",
              "const": "mdQuote"
            },
            {
              "type": "string",
              "const": "mdQuoteBorder"
            },
            {
              "type": "string",
              "const": "muted"
            },
            {
              "type": "string",
              "const": "success"
            },
            {
              "type": "string",
              "const": "syntaxComment"
            },
            {
              "type": "string",
              "const": "syntaxFunction"
            },
            {
              "type": "string",
              "const": "syntaxKeyword"
            },
            {
              "type": "string",
              "const": "syntaxNumber"
            },
            {
              "type": "string",
              "const": "syntaxOperator"
            },
            {
              "type": "string",
              "const": "syntaxPunctuation"
            },
            {
              "type": "string",
              "const": "syntaxString"
            },
            {
              "type": "string",
              "const": "syntaxType"
            },
            {
              "type": "string",
              "const": "syntaxVariable"
            },
            {
              "type": "string",
              "const": "text"
            },
            {
              "type": "string",
              "const": "thinkingHigh"
            },
            {
              "type": "string",
              "const": "thinkingLow"
            },
            {
              "type": "string",
              "const": "thinkingMedium"
            },
            {
              "type": "string",
              "const": "thinkingMinimal"
            },
            {
              "type": "string",
              "const": "thinkingOff"
            },
            {
              "type": "string",
              "const": "thinkingText"
            },
            {
              "type": "string",
              "const": "thinkingXhigh"
            },
            {
              "type": "string",
              "const": "toolDiffAdded"
            },
            {
              "type": "string",
              "const": "toolDiffContext"
            },
            {
              "type": "string",
              "const": "toolDiffRemoved"
            },
            {
              "type": "string",
              "const": "toolOutput"
            },
            {
              "type": "string",
              "const": "toolTitle"
            },
            {
              "type": "string",
              "const": "userMessageText"
            },
            {
              "type": "string",
              "const": "warning"
            }
          ]
        },
        {
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        },
        {
          "type": "string",
          "const": ""
        },
        {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$"
        }
      ],
      "default": "#87d7ff",
      "description": "URL color as an ANSI-256 index, hex color, theme color name, or empty string to disable highlighting."
    }
  }
}
